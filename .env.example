# Zupee Claw - Environment Configuration
# Copy to .env and customize: cp .env.example .env

# Claw version (pinned)
OPENCLAW_VERSION=2026.4.2

# Full path to the repository Claw works on
# Claude Code operates inside this directory
# Use absolute path (~ is expanded by setup.sh)
# Examples:
#   WORKSPACE=~/workspace/my-backend
#   WORKSPACE=/Users/john/workspace/ai-travel-agent
WORKSPACE=~/workspace/my-project

# Ollama execution mode:
#   native  - Ollama runs natively on the host (macOS Metal GPU acceleration)
#   docker  - Ollama runs inside a Docker container (Linux/CI, CPU only)
#   auto    - Detect automatically: native on macOS, docker on Linux (default)
# OLLAMA_MEM and OLLAMA_CPUS are only used in docker mode.
OLLAMA_MODE=auto

# Ollama model for local inference
# Set OLLAMA_MODEL_MEM to the model's memory requirement (GiB).
# setup.sh uses this to size the Ollama container and preflight-check Docker memory.
# Memory depends on context window size (contextWindow in openclaw.json, default 64K).
#
# Model                  OLLAMA_MODEL          OLLAMA_MODEL_MEM (64K ctx)
# -----------------------------------------------------------------------
# Gemma 4 E2B (rec.)     gemma4:e2b            10
# Qwen 3.5 1.7B          qwen3.5:1.7b          3
# Qwen 3.5 4B            qwen3.5:4b            10
# Qwen 3.5 9B            qwen3.5:9b            10
# Qwen 3 8B              qwen3:8b              8
# Llama 3.1 8B           llama3.1:8b           8
# DeepSeek Coder V2      deepseek-coder-v2     9
# Mistral 7B             mistral:7b            8
# CodeLlama 7B           codellama:7b          8
OLLAMA_MODEL=gemma4:e2b
OLLAMA_MODEL_MEM=10

# Slack integration (optional)
# Claw communicates AS the developer (not as a bot) using the developer's
# own Slack user token. Messages appear from you, not from a bot.
#
# Setup (one-time, admin creates the Slack app):
#   1. Create Slack app at api.slack.com/apps → enable Socket Mode
#   2. Generate App-Level Token with connections:write scope (xapp-...)
#   3. Add User Token Scopes (NOT bot scopes):
#      chat:write, channels:history, channels:read, groups:history,
#      groups:read, im:history, im:read, im:write, users:read,
#      reactions:read, reactions:write, pins:read, files:read
#   4. Each developer installs the app → gets their own User Token (xoxp-...)
#
# SLACK_APP_TOKEN is shared (same for all developers)
# SLACK_USER_TOKEN is unique per developer (from OAuth install)
#
# SLACK_APP_TOKEN=xapp-your-app-token
# SLACK_USER_TOKEN=xoxp-your-user-token
