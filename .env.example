# Zupee Claw - Environment Configuration
# Copy to .env and customize: cp .env.example .env

# Claw version (pinned)
OPENCLAW_VERSION=2026.4.2

# Default repository under $WORKSPACE_DIR/
# Change this to whatever project directory you're working on
REPO=my-project

# Host workspace root directory
# All repos live under this path (e.g., $WORKSPACE_DIR/$REPO)
WORKSPACE_DIR=~/workspace

# Ollama execution mode:
#   native  - Ollama runs natively on the host (macOS Metal GPU acceleration)
#   docker  - Ollama runs inside a Docker container (Linux/CI, CPU only)
#   auto    - Detect automatically: native on macOS, docker on Linux (default)
# OLLAMA_MEM and OLLAMA_CPUS are only used in docker mode.
OLLAMA_MODE=auto

# Ollama model for local inference
# Set OLLAMA_MODEL_MEM to the model's memory requirement (GiB).
# setup.sh uses this to size the Ollama container and preflight-check Docker memory.
# Memory depends on context window size (contextWindow in openclaw.json, default 64K).
#
# Model                  OLLAMA_MODEL          OLLAMA_MODEL_MEM (64K ctx)
# -----------------------------------------------------------------------
# Qwen 3.5 1.7B          qwen3.5:1.7b          3
# Qwen 3.5 4B            qwen3.5:4b            10
# Qwen 3.5 9B            qwen3.5:9b            10
# Llama 3.1 8B           llama3.1:8b           8
# DeepSeek Coder V2      deepseek-coder-v2     9
# Mistral 7B             mistral:7b            8
# CodeLlama 7B           codellama:7b          8
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_MODEL_MEM=3

# Slack integration (optional - see docs/slack-integration.md)
# Socket Mode requires both tokens:
# SLACK_BOT_TOKEN=xoxb-your-bot-token     (Bot User OAuth Token)
# SLACK_APP_TOKEN=xapp-your-app-token     (App-Level Token with connections:write scope)
