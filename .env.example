# Zupee Claw - Environment Configuration
# Copy to .env and customize: cp .env.example .env

# Claw version (pinned)
OPENCLAW_VERSION=2026.4.2

# Default repository under $WORKSPACE_DIR/
# Change this to whatever project directory you're working on
REPO=my-project

# Host workspace root directory
# All repos live under this path (e.g., $WORKSPACE_DIR/$REPO)
WORKSPACE_DIR=~/workspace

# Ollama model for local inference
# Alternatives: llama3.1, codellama, deepseek-coder-v2, mistral
OLLAMA_MODEL=qwen3.5
