{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 3000
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "sandbox": {
        "mode": "all"
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "models": [
          {
            "id": "qwen3.5",
            "name": "Qwen 3.5",
            "api": "ollama"
          }
        ]
      }
    }
  },
  "tools": {
    "allow": ["read", "write", "edit", "message"],
    "deny": ["exec", "bash", "process", "browser", "canvas"],
    "elevated": {
      "enabled": false
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket"
    }
  }
}
