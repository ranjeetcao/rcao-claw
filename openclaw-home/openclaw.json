{
  "gateway": {
    "mode": "local",
    "bind": "0.0.0.0",
    "port": 3000
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "sandbox": {
        "mode": "all"
      }
    }
  },
  "models": {
    "_comment": "Set OLLAMA_MODEL in .env to change the default model",
    "default": "qwen3.5",
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434"
      }
    }
  },
  "tools": {
    "allow": ["read", "write", "edit", "message"],
    "deny": ["exec", "bash", "process", "browser", "canvas"],
    "elevated": {
      "enabled": false
    }
  }
}
