{
  "gateway": {
    "mode": "local",
    "bind": "custom",
    "customBindHost": "0.0.0.0",
    "port": 3000
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "sandbox": {
        "mode": "off"
      },
      "model": {
        "primary": "ollama/qwen3.5:4b"
      },
      "timeoutSeconds": 300,
      "thinkingDefault": "low"
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "models": [
          {
            "id": "qwen3.5:4b",
            "name": "Qwen 3.5 4B",
            "api": "ollama",
            "contextWindow": 65536
          }
        ]
      }
    }
  },
  "tools": {
    "allow": [
      "read",
      "write",
      "edit",
      "message"
    ],
    "deny": [
      "exec",
      "bash",
      "process",
      "browser",
      "canvas"
    ],
    "elevated": {
      "enabled": false
    }
  },
  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket"
    }
  }
}
