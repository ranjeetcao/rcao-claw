openclaw-home/openclaw.json.bak.*
openclaw-home/openclaw.json.clobbered.*
openclaw-home/update-check.json

# Logs
logs/*.log
logs/squid/

# Rate limit files (runtime)
*.rate-limit
*.rate-limit.lock
*.rate-limit.tmp.*
